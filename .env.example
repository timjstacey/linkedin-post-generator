ANTHROPIC_API_KEY=
TAVILY_API_KEY=
TAVILY_MAX_SEARCHES=5         # max Tavily searches per research run (default: 5)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=        # populated by auth:linkedin (expires ~60 days)
LINKEDIN_PERSON_URN=          # populated by auth:linkedin
RESEARCH_TOPIC=               # comma-separated list, e.g. "AI in software engineering,TypeScript best practices,Developer productivity"
HASHTAGS=                     # comma-separated, e.g. AI,SoftwareEngineering
GITHUB_TOKEN=                 # auto-provided in Actions; set manually for local runs
GITHUB_REPO=                  # owner/repo format
