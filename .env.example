ANTHROPIC_API_KEY=
TAVILY_API_KEY=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=        # populated by auth:linkedin / refresh:linkedin
LINKEDIN_REFRESH_TOKEN=       # populated by auth:linkedin (valid ~1 year)
